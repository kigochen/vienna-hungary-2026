rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /votes/{placeId} {
      // Read: 任何人可以讀取票數（公開資訊）
      allow read: if true;
      
      // Create: 如果 document 不存在，且有有效的 anonymous auth uid
      allow create: if request.auth != null
                    && (!exists(/databases/$(database)/documents/votes/$(placeId))
                        || request.auth.uid not in resource.data.voters);
      
      // Update: 只能遞增票數（count++）且只能加入自己的 uid 到 voters array
      allow update: if request.auth != null
                    && request.resource.data.count == resource.data.count + 1
                    && request.resource.data.voters.size() == resource.data.voters.size() + 1
                    && request.auth.uid in request.resource.data.voters
                    && request.auth.uid not in resource.data.voters;
      
      // Delete: 禁止刪除投票記錄
      allow delete: if false;
    }
  }
}
